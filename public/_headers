# Custom headers for Cloudflare Pages

# Prevent caching of HTML files
/*.html
  Cache-Control: no-cache, no-store, must-revalidate

/admin/*
  Cache-Control: no-cache, no-store, must-revalidate

# Cache static assets
/assets/*
  Cache-Control: public, max-age=31536000, immutable

/admin/assets/*
  Cache-Control: public, max-age=31536000, immutable
